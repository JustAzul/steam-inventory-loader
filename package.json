{
  "name": "azul-steam-inventory-loader",
  "version": "4.0.0-alpha.8",
  "description": "Steam inventory loader with field selection, LRU cache, provider chain fallback, and adaptive workers",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "steam",
    "inventory",
    "loader",
    "steam-inventory",
    "trading",
    "cs2",
    "justazul"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage .tsbuildinfo",
    "update-fields": "node scripts/update-fields.mjs",
    "prepublishOnly": "npm run build"
  },
  "author": "https://justazul.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/JustAzul/steam-inventory-loader.git"
  },
  "bugs": {
    "url": "https://github.com/JustAzul/steam-inventory-loader/issues"
  },
  "homepage": "https://github.com/JustAzul/steam-inventory-loader",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.7.8",
    "hpagent": "^1.2.0",
    "lru-cache": "^10.4.3",
    "piscina": "^5.1.4"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
