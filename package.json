{
  "name": "azul-steam-inventory-loader",
  "version": "4.0.0",
  "description": "TypeScript library for loading Steam user inventories with error handling and request management",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "azul",
    "inventory",
    "justazul.com",
    "justazul.xyz",
    "justazul",
    "loader",
    "steam inventory loader",
    "steam inventory",
    "steam"
  ],
  "scripts": {
    "build": "tsc",
    "format": "prettier --config .prettierrc --write \"src/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prebuild": "rimraf ./dist",
    "test": "jest",
    "test:facade": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.esm.ts",
    "type-check": "tsc --noEmit"
  },
  "author": "https://justazul.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/JustAzul/steam-inventory-loader.git"
  },
  "bugs": {
    "url": "https://github.com/JustAzul/steam-inventory-loader/issues"
  },
  "homepage": "https://github.com/JustAzul/steam-inventory-loader",
  "license": "ISC",
  "dependencies": {
    "@types/cookie": "^0.6.0",
    "agentkeepalive": "^4.2.1",
    "axios": "^1.10.0",
    "axios-cookiejar-support": "^6.0.3",
    "axios-retry": "^4.5.0",
    "cookie": "^1.0.2",
    "hpagent": "^1.1.0",
    "inversify": "^7.5.4",
    "reflect-metadata": "^0.2.2",
    "socks-proxy-agent": "^8.0.5",
    "status-code-enum": "^1.0.0",
    "steamid": "^2.1.0",
    "tough-cookie": "^5.1.2",
    "tsyringe": "^4.10.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.27.2",
    "@eslint/js": "^9.29.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.3",
    "@types/steamid": "^2.0.3",
    "@types/tough-cookie": "^4.0.1",
    "babel-jest": "^30.0.2",
    "eslint": "^9.29.0",
    "eslint-import-resolver-typescript": "^4.4.3",
    "eslint-plugin-boundaries": "^5.0.1",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-sort-keys": "^2.3.5",
    "globals": "^16.2.0",
    "jest": "^30.0.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.34.1"
  }
}
